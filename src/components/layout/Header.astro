---
import { Menu } from 'lucide-astro';

const currentPath = Astro.url.pathname;

const navLinks = [
  {
    href: '/',
    label: 'Home',
  },
  {
    href: '/research',
    label: 'Research',
  },
  {
    href: '/mathematics',
    label: 'Mathematics',
  },
  {
    href: '/quant-finance',
    label: 'Quant Finance',
  },
  {
    href: '/projects',
    label: 'Projects',
  },
  {
    href: '/cv',
    label: 'CV',
  },
  {
    href: '/contact',
    label: 'Contact',
  },
];

const isActive = (href: string) => {
  if (href === '/') {
    return currentPath === '/';
  }

  return currentPath.startsWith(href);
};
---

<header class="border-b border-line py-5 sm:py-6">
  <div class="flex items-center justify-between gap-4">
    <a
      href="/"
      class="max-w-full pr-4 font-serif text-xs font-bold leading-tight tracking-wide text-navy sm:text-sm"
    >
      JOSE SUÁREZ ARES - W0LFPY
    </a>

    <details class="relative md:hidden">
      <summary class="flex h-10 w-10 list-none items-center justify-center border border-divider bg-white text-navy transition-colors hover:border-navy [&::-webkit-details-marker]:hidden">
        <span class="sr-only">Open navigation menu</span>
        <Menu class="h-5 w-5" strokeWidth={1.8} />
      </summary>

      <nav class="absolute right-0 top-full z-20 mt-3 flex min-w-[220px] flex-col border border-divider bg-paper p-4 text-xs text-slate-700 shadow-[0_12px_30px_rgba(31,41,51,0.08)]">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'border-b border-divider py-3 last:border-b-0 transition-colors duration-200 hover:text-navy',
                isActive(link.href)
                  ? 'font-semibold text-navy'
                  : 'text-slate-600',
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </details>

    <nav class="hidden flex-wrap justify-end gap-x-4 gap-y-2 text-xs text-slate-600 md:flex md:w-auto">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'whitespace-nowrap transition-colors duration-200 hover:text-navy',
              isActive(link.href)
                ? 'font-semibold text-navy underline underline-offset-8 decoration-1'
                : 'text-slate-600',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
