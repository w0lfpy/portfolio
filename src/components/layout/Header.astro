---
import { Menu } from 'lucide-astro';

const currentPath = Astro.url.pathname;

const navLinks = [
  {
    href: '/',
    label: 'Home',
  },
  {
    href: '/research',
    label: 'Research',
  },
  {
    href: '/mathematics',
    label: 'Mathematics',
  },
  {
    href: '/quant-finance',
    label: 'Quant Finance',
  },
  {
    href: '/projects',
    label: 'Projects',
  },
  {
    href: '/cv',
    label: 'CV',
  },
  {
    href: '/contact',
    label: 'Contact',
  },
];

const isActive = (href: string) => {
  if (href === '/') {
    return currentPath === '/';
  }

  return currentPath.startsWith(href);
};
---

<header class="relative border-b border-line py-6">
  <div class="flex items-start justify-between gap-4 md:items-center">
    <a href="/" class="max-w-[13rem] font-serif text-sm font-bold leading-7 tracking-wide text-navy sm:max-w-none">
      JOSE SUÁREZ ARES - W0LFPY
    </a>

    <nav class="hidden items-center gap-5 text-xs text-slate-600 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'transition-colors duration-200 hover:text-navy',
              isActive(link.href)
                ? 'font-semibold text-navy underline underline-offset-8 decoration-1'
                : 'text-slate-600',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <details class="relative md:hidden">
      <summary class="flex cursor-pointer list-none items-center justify-center border border-line p-2 text-slate-700 transition-colors hover:text-navy">
        <Menu class="h-5 w-5" strokeWidth={2} />
        <span class="sr-only">Open navigation menu</span>
      </summary>

      <nav class="absolute right-0 top-full z-20 mt-3 flex min-w-[12rem] flex-col border border-divider bg-white p-3 shadow-sm">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'px-2 py-2 text-sm transition-colors duration-200 hover:text-navy',
                isActive(link.href)
                  ? 'font-semibold text-navy underline underline-offset-4 decoration-1'
                  : 'text-slate-600',
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </details>
  </div>
</header>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
