---
const currentPath = Astro.url.pathname;

const navLinks = [
  {
    href: '/',
    label: 'Home',
  },
  {
    href: '/research',
    label: 'Research',
  },
  {
    href: '/mathematics',
    label: 'Mathematics',
  },
  {
    href: '/quant-finance',
    label: 'Quant Finance',
  },
  {
    href: '/projects',
    label: 'Projects',
  },
  {
    href: '/cv',
    label: 'CV',
  },
  {
    href: '/contact',
    label: 'Contact',
  },
];

const isActive = (href: string) => {
  if (href === '/') {
    return currentPath === '/';
  }

  return currentPath.startsWith(href);
};
---

<header class="flex items-center justify-between border-b border-line py-6">
  <a href="/" class="font-serif text-sm font-bold tracking-wide text-navy">
    JOSE SUÁREZ ARES - W0LFPY
  </a>

  <nav class="flex gap-5 text-xs text-slate-600">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'transition-colors duration-200 hover:text-navy',
            isActive(link.href)
              ? 'font-semibold text-navy underline underline-offset-8 decoration-1'
              : 'text-slate-600',
          ]}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</header>