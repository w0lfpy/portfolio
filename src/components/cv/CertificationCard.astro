---
interface Props {
  name: string;
  issuer: string;
  period: string;
  description: string;
  certificateUrl?: string;
}

const { name, issuer, period, description, certificateUrl } = Astro.props;
---

<article class="flex h-full flex-col border border-divider bg-white p-5">
  <header>
    <h3 class="font-sans text-xl font-bold leading-7 text-slate-900">
      {name}
    </h3>

    <p class="mt-2 text-[11px] font-bold uppercase tracking-[0.16em] text-navy">
      {period}
    </p>

    <p class="mt-3 font-serif text-sm italic text-slate-800">
      {issuer}
    </p>
  </header>

  <p class="mt-5 text-sm leading-7 text-slate-700">
    {description}
  </p>

  {
    certificateUrl && (
      <a
        href={certificateUrl}
        target="_blank"
        rel="noreferrer"
        class="mt-auto pt-5 text-xs font-bold uppercase tracking-[0.16em] text-navy hover:underline"
      >
        View Credential
      </a>
    )
  }
</article>