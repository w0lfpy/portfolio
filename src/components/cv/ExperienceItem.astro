---
interface Props {
  title: string;
  company: string;
  location: string;
  period: string;
  bullets: string[];
}

const { title, company, location, period, bullets } = Astro.props;
---

<article class="relative">
  <span class="absolute -left-[37px] top-2 h-2.5 w-2.5 rounded-full bg-navy"></span>

  <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
    <div>
      <h3 class="font-sans text-2xl font-bold tracking-wide text-slate-900">
        {title}
      </h3>

      <p class="mt-2 font-serif text-base text-slate-900">
        {company} | {location}
      </p>
    </div>

    <span class="w-fit bg-[#E2E7F5] px-4 py-2 text-sm text-slate-900">
      {period}
    </span>
  </div>

  <ul class="mt-5 list-disc space-y-3 pl-5 font-serif text-base leading-7 text-slate-900">
    {
      bullets.map((bullet) => (
        <li>{bullet}</li>
      ))
    }
  </ul>
</article>