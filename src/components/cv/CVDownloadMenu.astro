---
import { Download } from 'lucide-astro';

interface Props {
  englishUrl: string;
  spanishUrl: string;
}

const { englishUrl, spanishUrl } = Astro.props;
---

<details class="relative w-full sm:w-auto">
  <summary
    class="flex cursor-pointer list-none items-center justify-center gap-2 border border-navy bg-navy px-4 py-2 text-center text-xs font-semibold uppercase tracking-wider text-white transition-colors duration-200 hover:bg-transparent hover:text-navy"
  >
    <Download class="h-3.5 w-3.5" strokeWidth={2} />
    Download PDF CV
  </summary>

  <div class="mt-3 flex flex-col border border-divider bg-white shadow-sm sm:absolute sm:right-0 sm:z-20 sm:mt-2 sm:w-52">
    <a
      href={englishUrl}
      download
      class="block border-b border-divider px-4 py-3 text-xs font-semibold uppercase tracking-wider text-slate-700 transition-colors hover:bg-[#E2E7F5] hover:text-navy"
    >
      English Version
    </a>

    <a
      href={spanishUrl}
      download
      class="block px-4 py-3 text-xs font-semibold uppercase tracking-wider text-slate-700 transition-colors hover:bg-[#E2E7F5] hover:text-navy"
    >
      Spanish Version
    </a>
  </div>
</details>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
