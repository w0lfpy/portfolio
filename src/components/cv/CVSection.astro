---
interface Props {
  title: string;
  class?: string;
}

const { title, class: className = '' } = Astro.props;
---

<section class={`py-8 ${className}`}>
  <h2 class="border-b border-slate-500 pb-2 text-xs font-bold uppercase tracking-[0.18em] text-slate-900">
    {title}
  </h2>

  <slot />
</section>