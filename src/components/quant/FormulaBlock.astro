---
interface Props {
  title?: string;
  formula: string;
  note?: string;
}

const { title, formula, note } = Astro.props;
---

<div class="border border-divider bg-[#E2E7F5] px-5 py-4">
  {
    title && (
      <p class="mb-2 text-xs font-bold uppercase tracking-[0.16em] text-slate-600">
        {title}
      </p>
    )
  }

  <pre class="overflow-x-auto font-mono text-xs leading-6 text-slate-800">{formula}</pre>

  {
    note && (
      <p class="mt-2 text-xs leading-5 text-slate-600">
        {note}
      </p>
    )
  }
</div>