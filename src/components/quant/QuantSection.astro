---
import FormulaBlock from './FormulaBlock.astro';

interface Props {
  id: string;
  title: string;
  description: string;
  bullets: string[];
  formulaTitle?: string;
  formula?: string;
  formulaNote?: string;
}

const {
  id,
  title,
  description,
  bullets,
  formulaTitle,
  formula,
  formulaNote,
} = Astro.props;
---

<section id={id} class="min-w-0 scroll-mt-24 py-10">
  <h2 class="font-sans text-2xl font-bold tracking-tight text-slate-900">
    {title}
  </h2>

  <p class="mt-4 max-w-3xl break-words pr-2 font-serif text-base leading-8 text-slate-800 sm:pr-0">
    {description}
  </p>

  {
    formula && (
      <div class="mt-6">
        <FormulaBlock
          title={formulaTitle}
          formula={formula}
          note={formulaNote}
        />
      </div>
    )
  }

  <ul class="mt-6 list-disc space-y-3 pl-5 pr-2 font-serif text-base leading-7 break-words text-slate-900 sm:pr-0">
    {
      bullets.map((bullet) => (
        <li>{bullet}</li>
      ))
    }
  </ul>
</section>
