---
const { title, description, type = 'note' } = Astro.props;
---

<article class="h-full border border-line bg-white px-4 py-4">
  <div class="flex items-start gap-2">
    <div class="min-w-0">
      <h3 class="font-sans text-base text-xl font-bold leading-5 text-navy">
        {title}
      </h3>

      <p class="mt-3 text-sm leading-7 text-slate-600">
        {description}
      </p>
    </div>
  </div>
</article>