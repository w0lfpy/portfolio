---
import {
  BarChart3,
  TrendingUp,
  CircleDollarSign,
  Sigma,
  Cpu,
  TerminalSquare,
} from 'lucide-astro';

interface Props {
  title: string;
  description: string;
  icon?: 'statistics' | 'timeseries' | 'finance' | 'optimization' | 'ml' | 'computing';
}

const { title, description, icon = 'statistics' } = Astro.props;

const icons = {
  statistics: BarChart3,
  timeseries: TrendingUp,
  finance: CircleDollarSign,
  optimization: Sigma,
  ml: Cpu,
  computing: TerminalSquare,
};
const Icon = icons[icon];
---

<article class="h-full border border-line bg-white px-4 py-4">
  <div class="flex items-start gap-2">
    <Icon class="mt-[3px] h-5 w-5 shrink-0 text-navy" strokeWidth={1.8} />

    <div class="min-w-0">
      <h3 class="font-sans text-base font-bold leading-5 text-slate-900">
        {title}
      </h3>

      <p class="mt-3 text-sm leading-7 text-slate-600">
        {description}
      </p>
    </div>
  </div>
</article>