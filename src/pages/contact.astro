---
import BaseLayout from '../layouts/BaseLayout.astro';

import {
  Mail,
  Github,
  Linkedin,
  FileText,
  ArrowRight,
  Briefcase,
} from 'lucide-astro';

const contactLinks = [
  {
    label: 'Email',
    value: 'w0lfquant2000@gmail.com',
    href: 'mailto:w0lfquant2000@gmail.com',
    icon: Mail,
  },
  {
    label: 'GitHub',
    value: 'github.com/w0lfpy',
    href: 'https://github.com/w0lfpy',
    icon: Github,
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/jose-suarez-ares',
    href: 'https://www.linkedin.com/in/jose-suarez-ares/',
    icon: Linkedin,
  },
  {
    label: 'SSRN / arXiv',
    value: 'Author Profile: Pending',
    href: '#',
    icon: FileText,
  },
];

const metadata = [
  {
    label: 'Timezone',
    value: 'CET / CEST',
  },
  {
    label: 'PGP Fingerprint',
    value: 'Pending',
  },
  {
    label: 'Status',
    value: 'Active',
    active: true,
  },
  {
    label: 'Version',
    value: 'v1.0-stable',
  },
];
---

<BaseLayout title="Contact - Quant Research">
  <section class="border-y border-divider py-12">
    <div class="grid gap-12 lg:grid-cols-[1fr_420px]">
      <div class="pr-0 lg:border-r lg:border-divider lg:pr-16">
        <h1 class="font-sans text-2xl font-bold tracking-tight text-navy sm:text-3xl">
          Contact & Collaboration
        </h1>

        <p class="mt-6 max-w-xl font-serif text-base leading-8 text-slate-700">
          Open to conversations around quantitative research, machine learning,
          financial markets, computing, Data Engineering, and rigorous technical
          collaboration.
        </p>

        <div class="mt-12 max-w-xl border border-divider bg-[#F1F4FC] px-7 py-6">
          <h2 class="text-xs font-bold uppercase tracking-[0.18em] text-navy">
            Availability Notice
          </h2>

          <p class="mt-4 text-sm leading-6 text-slate-700">
            Expected response latency: &lt; 48 hours for academic and professional
            inquiries. Please utilize formal communication channels for institutional
            partnership requests.
          </p>
        </div>
      </div>

      <aside>
        <h2 class="text-[11px] font-bold uppercase tracking-[0.2em] text-slate-900">
          Professional Directory
        </h2>

        <div class="mt-6 divide-y divide-divider">
          {
            contactLinks.map((item) => {
              const Icon = item.icon;

              return (
                <a
                  href={item.href}
                  target={item.href.startsWith('http') ? '_blank' : undefined}
                  rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
                  class="group flex items-center justify-between gap-6 py-4"
                >
                  <div class="flex items-center gap-4">
                    <Icon class="h-4 w-4 text-navy" strokeWidth={1.8} />

                    <div>
                      <p class="text-xs font-semibold text-slate-700">
                        {item.label}
                      </p>
                      <p class="mt-1 text-sm text-slate-900">
                        {item.value}
                      </p>
                    </div>
                  </div>

                  <ArrowRight
                    class="h-4 w-4 text-slate-400 transition-transform duration-200 group-hover:translate-x-1 group-hover:text-navy"
                    strokeWidth={1.8}
                  />
                </a>
              );
            })
          }
        </div>

        <div class="mt-12 flex h-36 items-center justify-center overflow-hidden border border-divider bg-[#E2E7F5]">
          <div
            class="relative flex h-full w-full items-center justify-center bg-cover bg-center"
            style="background-image: url('/images/institutional-network-bg.svg');"
          >
            <div class="absolute inset-0 bg-white/20"></div>

            <div class="z-10 border border-blue-academic/60 bg-white/90 px-6 py-3 shadow-sm backdrop-blur-[1px]">
              <span class="text-[10px] font-bold uppercase tracking-[0.18em] text-blue-academic">
                Institutional Base: Madrid, Spain
              </span>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="grid gap-6 border-b border-divider py-8 sm:grid-cols-2 lg:grid-cols-4">
    {
      metadata.map((item) => (
        <div>
          <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500">
            {item.label}
          </p>

          <p
            class:list={[
              'mt-2 text-xs font-medium uppercase tracking-wider',
              item.active
                ? 'w-fit bg-emerald-100 px-2 py-0.5 text-emerald-700'
                : 'text-slate-700',
            ]}
          >
            {item.value}
          </p>
        </div>
      ))
    }
  </section>
</BaseLayout>