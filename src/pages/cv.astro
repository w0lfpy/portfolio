];

const graduateModules = [
  {
    module: 'Stochastic Calculus for Finance',
    result: 'In Progress',
  },
  {
    module: 'Machine Learning in Finance',
    result: 'In Progress',
  },
];

const undergraduateCoreModules = [
  {
    module: 'Data Structures',
    result: 'First Class',
  },
  {
    module: 'Algorithms',
    result: 'First Class',
  },
  {
