---

<BaseLayout title="CV - Quant Research">
  <section class="pb-8">
    <div class="flex flex-col gap-6 border-b-4 border-slate-900 pb-8 md:flex-row md:items-start md:justify-between">
      <div>
        <h1 class="font-sans text-4xl font-bold tracking-tight text-slate-900">
          Curriculum Vitae
        </h1>

        <p class="mt-3 font-serif text-base italic text-slate-700">
          Quantitative Developer / Software Engineering / Mathematical Finance & Machine Learning
        </p>
      </div>

      <CVDownloadMenu
        englishUrl="/cv/jose-suarez-ares-cv-en.pdf"
        spanishUrl="/cv/jose-suarez-ares-cv-es.pdf"
      />
    </div>
  </section>

  <section class="grid gap-12 py-10 lg:grid-cols-[280px_1fr]">
    <div>
      <h2 class="border-b border-slate-500 pb-2 text-xs font-bold uppercase tracking-[0.18em] text-slate-900">
        Research Interests
      </h2>

      <ul class="mt-4 list-disc space-y-3 pl-5 font-serif text-base leading-7 text-slate-900">
        {
          researchInterests.map((interest) => (
            <li>{interest}</li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="border-b border-slate-500 pb-2 text-xs font-bold uppercase tracking-[0.18em] text-slate-900">
        Personal Statement
      </h2>

      <p class="mt-4 max-w-4xl font-serif text-lg leading-9 text-slate-900">
        Software engineer with a strong interest in data-intensive systems, mathematical modelling and machine learning. 
        I am currently developing a deeper foundation in advanced postgraduate mathematics and quantitative finance, with the goal of applying rigorous analytical methods to financial markets and complex data environments. 
        My background in data pipelines, cloud infrastructure and security analytics allows me to bridge practical engineering with research-oriented computation, building systems that are reliable, interpretable and technically robust.
      </p>
    </div>
  </section>

  <CVSection title="Work Experience">
    <div class="relative mt-8 space-y-12 border-l border-slate-400 pl-8">
      {
        workExperience.map((item) => (
          <ExperienceItem
            title={item.title}
            company={item.company}
            location={item.location}
            period={item.period}
            bullets={item.bullets}
          />
        ))
      }
    </div>
  </CVSection>

  <CVSection title="Education">
    <div class="mt-8 space-y-10">
      {
        education.map((item) => (
          <EducationItem
            degree={item.degree}
            institution={item.institution}
            period={item.period}
            gpa={item.gpa}
          />
        ))
      }
    </div>
  </CVSection>

  <CVSection title="Certifications">
    <div class="mt-6 grid gap-5 md:grid-cols-3">
      {
        certifications.map((cert) => (
          <CertificationCard
            name={cert.name}
            issuer={cert.issuer}
            period={cert.period}
            description={cert.description}
            certificateUrl={cert.certificateUrl}
          />
        ))
      }
    </div>
  </CVSection>

  <CVSection title="Technical Proficiency">
    <ProficiencyTable items={technicalProficiency} />
  </CVSection>

  <CVSection title="Selected Coursework">
    <div class="mt-8 grid gap-10 lg:grid-cols-2">
      <!-- <CourseworkTable
        title="Graduate Modules"
        resultLabel="Standing"
        items={graduateModules}
      /> -->

      <CourseworkTable
        title="Undergraduate Core Modules"
        resultLabel="Standing"
        items={undergraduateCoreModules}
      />

      <CourseworkTable
        title="Undergraduate Specialized Modules"
        resultLabel="Standing"
        items={undergraduateSpecializedModules}
      />
    </div>
  </CVSection>

  <section class="pt-8">
    <div class="h-40 overflow-hidden border border-divider bg-[#E2E7F5]">
      <div
        class="h-full w-full bg-cover bg-center opacity-80"
        style="background-image: url('/images/institutional-network-bg.svg');"
      >
      </div>
    </div>
  </section>
</BaseLayout>