---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResearchCard from '../components/cards/ResearchCard.astro';
import PublicationItem from '../components/article/PublicationItem.astro';
---

<BaseLayout title="Research - Quant Research">
  <h1 class="font-serif text-4xl font-semibold text-slate-900">
    Research & Academic Focus
  </h1>

  <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600">
    Working papers, research notes and technical investigations in mathematics, statistics, quantitative
    finance, machine learning and computing.
  </p>

  <section class="mt-10">
    <h2 class="border-b border-divider pb-3 text-m font-semibold text-slate-900">
      Primary Research Areas
    </h2>

    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <ResearchCard
        title="Time-Series Analysis & Volatility Modelling"
        description="Focusing on non-stationary properties, fractal integration, and rough volatility paradigms for robust forecasting."
      />

      <ResearchCard
        title="Deep Learning in Financial Markets"
        description="Applying sequence models (LSTM, Transformers) to noisy, high-dimensional market data for signal extraction."
      />

      <ResearchCard
        title="Market Microstructure & Order Flow"
        description="Modeling limit order book dynamics, liquidity provision, and short-term price impact functions."
      />

      <ResearchCard
        title="Stochastic Calculus & Derivatives Pricing"
        description="Developing numerical methods and closed-form approximations for exotic options under complex jump-diffusion models."
      />
    </div>
  </section>

  <section class="mt-10">
    <h2 class="border-b border-divider pb-3 text-m font-semibold text-slate-900">
      Selected Publications
    </h2>

    <div class="mt-6 grid gap-4">
      <PublicationItem
        index={1}
        title="High-Frequency Microstructure Analysis in Fragmented Equity Markets"
        year="2023"
        venue="White Paper"
        pdfUrl="/papers/test.pdf"
        label="PDF Preprint"
      />
      <PublicationItem
        index={2}
        title="High-Frequency Microstructure Analysis in Fragmented Equity Markets"
        year="2023"
        venue="White Paper"
        pdfUrl="/papers/test.pdf"
        label="PDF Preprint"
      />
    </div>
  </section>

  <section class="mt-10 grid gap-4">
    <article class="border border-line bg-white p-6">
      <p class="text-[10px] font-semibold uppercase tracking-widest text-navy">
        Working Paper
      </p>

      <h2 class="mt-3 font-serif text-2xl font-semibold text-slate-900">
        High-Frequency Microstructure Analysis in Fragmented Equity Markets
      </h2>

      <p class="mt-3 text-sm leading-7 text-slate-600">
        Research draft focused on liquidity provision, spread dynamics and
        market fragmentation across trading venues.
      </p>
    </article>
  </section>
</BaseLayout>