---
import BaseLayout from '../layouts/BaseLayout.astro';
import ButtonLink from '../components/ui/ButtonLink.astro';
import Divider from '../components/ui/Divider.astro';
import FocusCard from '../components/cards/FocusCard.astro';
---

<BaseLayout title="Home - Quant Research">
  <section class="max-w-3xl">
    <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-navy">
      Quant Finance · Machine Learning · Computing
    </p>

    <h1 class="font-serif text-4xl font-semibold tracking-tight text-slate-900 md:text-5xl">
      Building rigorous foundations in software engineering, mathematics,
      statistics and machine learning applied to quantitative finance.
    </h1>

    <p class="mt-6 max-w-2xl text-sm leading-7 text-slate-600">
      This website documents my academic and technical journey toward quantitative finance and research-oriented software development, combining practical
      engineering experience with a growing focus on advanced mathematics, data-intensive systems and financial machine learning.
    </p>

    <div class="mt-8 flex gap-4">
	  <ButtonLink href="/research" variant="primary">
		Research
	  </ButtonLink>
	  <ButtonLink href="/projects" variant="secondary">
		Projects
	  </ButtonLink>
	  <ButtonLink href="/cv" variant="ghost">
  		View CV →
	  </ButtonLink>
	</div>
  </section>

  <Divider class="my-12" />

  <section class="mt-12">
    <h2 class="border-b border-divider pb-3 text-m font-semibold text-slate-900">
      Research Focus
    </h2>

    <div class="mt-6 grid gap-4 md:grid-cols-3">
      <FocusCard
	    icon="statistics"
        title="Statistical Learning & Predictive Modelling"
        description="Applying advanced statistical methods to extract signals from noisy financial datasets, focusing on robust estimators and out-of-sample performance."
      />

      <FocusCard
	    icon="timeseries"
        title="Time Series & Stochastic Processes"
        description="Modeling asset dynamics using continuous-time stochastic calculus and discrete-time ARMA/GARCH frameworks for volatility estimation."
      />

      <FocusCard
	    icon="finance"
        title="Quantitative Finance"
        description="Developing systematic trading strategies, portfolio optimization techniques, and risk management models grounded in empirical finance."
      />

	  <FocusCard
	    icon="optimization"
        title="Optimization & Numerical Methods"
        description="Implementing convex optimization routines and numerical PDE solvers for derivatives pricing and portfolio allocation under constraints."
      />

      <FocusCard
	    icon="ml"
        title="Machine Learning"
        description="Exploring deep learning architectures, reinforcement learning, and NLP applied to alternative data for alpha generation."
      />

      <FocusCard
	    icon="computing"
        title="Computing"
        description="Building high-performance, data visualization, and computational tools using Python, C++, and specialized numerical libraries."
      />
    </div>
  </section>
</BaseLayout>
